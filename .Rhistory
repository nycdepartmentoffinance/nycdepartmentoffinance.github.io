all_tables <- read.csv("tables/all_tables.csv")
View(all_tables)
all_tables <- read.csv("tables/all_tables.csv") %>%
select(-X)
# library
library(DBI)
library(odbc)
library(dplyr)
library(stringr)
table_list <- all_tables %>%
rename(SCHEMA=TABLE_SCHEMA,
COLS=COLUMNS,
DATABASE=TABLE_CATALOG) %>%
filter(!stringr::str_ends(TABLE_NAME, '_20[0-9]{2}$') &
!(SCHEMA %in% c("dbo", "COMMON", "internal", "DATA_BACKUP", "DataBackup", "CONV", "NYC_STAGE"))) %>%
select(DATABASE, SCHEMA, TABLE_NAME, PREFIX, COLS, PRIMARY_KEYS, COLUMN_NAMES)
View(table_list)
write.csv(table_list, "tables/table_list.csv", na="")
write.csv(table_list, "tables/table_list.csv", na="")
library(dplyr)
library(readr)
library(DT)
#re-run every now and then to update df - note: might take a few minutes (especially because of IAS)
#source("generate_table_list.R")
table_data <- readr::read_csv("tables/table_list.csv") %>%
select(-1)
#| echo: false
#| warning: false
DT::datatable(table_data, escape = FALSE, filter = 'top', rownames = FALSE,
options = list(paging = FALSE, scrollCollapse = TRUE,
columnDefs = list(
# width limit for primary keys
list(
targets = c(2,5,6),
render = JS(
"function(data, type, row, meta) {",
"return type === 'display' && data.length > 15 ?",
"'<span title=\"' + data + '\">' + data.substr(0, 15) + '...</span>' : data;",
"}")),
# # width limit for table name
# list(
#  targets = 5,
#  render = JS(
#    "function(data, type, row, meta) {",
#    "return type === 'display' && data.length > 15 ?",
#    "'<span title=\"' + data + '\">' + data.substr(0, 15) + '...</span>' : data;",
#    "}")),
# # width limit for table name
# list(
#  targets = 6,
#  render = JS(
#    "function(data, type, row, meta) {",
#    "return type === 'display' && data.length > 15 ?",
#    "'<span title=\"' + data + '\">' + data.substr(0, 15) + '...</span>' : data;",
#    "}"))
))
) %>%
formatStyle(columns = "PREFIX", `max-width` = '60px') %>%
formatStyle(columns = "COLS", `max-width` = '60px')
